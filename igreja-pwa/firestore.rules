rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthed() {
      return request.auth != null;
    }

    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // Pode gerenciar conteúdo (eventos, avisos)
    function canManageContent() {
      return isAuthed() && getRole() in ['admin','lider','secretario','vice_secretario'];
    }

    // Pode gerenciar membros
    function canManageMembers() {
      return isAuthed() && getRole() in ['admin','secretario','vice_secretario'];
    }

    // Pode ver lista de membros
    function canViewMembers() {
      return isAuthed() && getRole() in ['admin','secretario','vice_secretario','lider','lider_ministerio','tesoureiro','vice_tesoureiro'];
    }

    // Dashboard / relatórios
    function canAccessDashboard() {
      return isAuthed() && getRole() in ['admin','secretario','vice_secretario','tesoureiro','vice_tesoureiro'];
    }

    // Só admin muda roles
    function isAdmin() {
      return isAuthed() && getRole() == 'admin';
    }

    // ── Usuários ──────────────────────────────────────────────
    match /users/{uid} {
      allow read:   if isAuthed() && (request.auth.uid == uid || canViewMembers());
      allow create: if isAuthed() && (request.auth.uid == uid || canManageMembers());
      allow update: if isAuthed() && (
        request.auth.uid == uid ||
        canManageMembers() ||
        // Impede membro de alterar o próprio role
        (request.auth.uid == uid && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']))
      );
      allow delete: if isAdmin();
    }

    // ── Eventos ───────────────────────────────────────────────
    match /events/{id} {
      allow read:   if true;
      allow write:  if canManageContent();
    }

    // ── Avisos ────────────────────────────────────────────────
    match /news/{id} {
      allow read:   if true;
      allow write:  if canManageContent();
    }

    // ── Pedidos de Oração ─────────────────────────────────────
    match /prayers/{id} {
      allow read:   if resource.data.isPublic == true || canViewMembers();
      allow create: if isAuthed();
      allow update: if isAuthed();
      allow delete: if canManageContent();
    }

    // ── Devocionais ───────────────────────────────────────────
    match /devotionals/{id} {
      allow read:   if true;
      allow write:  if isAdmin();
    }

    // ── Ministérios ───────────────────────────────────────────
    match /ministries/{id} {
      allow read:   if true;
      allow write:  if canManageContent();
    }

    // ── Fotos / Álbuns ────────────────────────────────────────
    match /albums/{id} {
      allow read:   if true;
      allow write:  if canManageContent();
    }
    match /photos/{id} {
      allow read:   if true;
      allow write:  if canManageContent();
    }

    // ── Configurações da Igreja ───────────────────────────────
    match /settings/{id} {
      allow read:   if true;
      allow write:  if isAdmin();
    }

    // ── Financeiro (futuro) ───────────────────────────────────
    match /finance/{id} {
      allow read:   if canAccessDashboard();
      allow write:  if isAuthed() && getRole() in ['admin','tesoureiro','vice_tesoureiro'];
    }
  }
}
